{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=192.168.1.2;Port=5432;Database=rava;Username=postgres;Password=YOUR_PASSWORD"
  },
  "Admin": {
    "Usernames": [ "your-admin-username" ]
  },
  "Moderator": {
    "Usernames": [ "your-moderator-username" ]
  },
  "HateSpeech": {
    "Enabled": true,
    "Terms": []
  },
  "Email": {
    "Enabled": true,
    "Host": "mail.gmx.com",
    "Port": 465,
    "Username": "your-account@gmx.com",
    "Password": "YOUR_GMX_PASSWORD",
    "FromAddress": "your-account@gmx.com",
    "FromName": "RAVA — Reactive Asteroid Venturing Agency",
    "AppBaseUrl": "http://localhost:5000",
    "UseStartTls": false,
    "UseSsl": true
  },
  "Market": {
    "UseLiveData": true,
    "SupplySymbols": {
      "DrillBits": "CAT",
      "FuelCells": "XOM",
      "LifeSupport": "JNJ",
      "CommModules": "QCOM"
    },
    "ReferenceCloses": {
      "CAT": 350,
      "XOM": 110,
      "JNJ": 155,
      "QCOM": 170
    }
  }
}
