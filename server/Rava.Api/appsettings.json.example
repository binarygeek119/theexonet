{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Hosting": {
    "ServeGameUi": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Port=5432;Database=YOUR_DATABASE;Username=YOUR_DB_USER;Password=YOUR_PASSWORD"
  },
  "Jwt": {
    "Key": "CHANGE_ME_MinimumLength32Characters!",
    "Issuer": "Rava.Api",
    "Audience": "Rava.Client"
  },
  "Admin": {
    "Usernames": [ "your-admin-username" ]
  },
  "Moderator": {
    "Usernames": [ "your-moderator-username" ]
  },
  "HateSpeech": {
    "Enabled": true,
    "Terms": []
  },
  "Email": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@example.com",
    "FromName": "RAVA — Reactive Asteroid Venturing Agency",
    "AppBaseUrl": "https://rava.binarygeek119.duckdns.org",
    "UseStartTls": true,
    "UseSsl": false
  },
  "Market": {
    "UseLiveData": true,
    "SupplySymbols": {
      "DrillBits": "CAT",
      "FuelCells": "XOM",
      "LifeSupport": "JNJ",
      "CommModules": "QCOM"
    },
    "ReferenceCloses": {
      "CAT": 350,
      "XOM": 110,
      "JNJ": 155,
      "QCOM": 170
    }
  },
  "StatusMonitor": {
    "ApiBaseUrl": "http://127.0.0.1:5000",
    "GameUrl": "https://rava.binarygeek119.duckdns.org/",
    "ApiPublicUrl": "https://ravaapi.binarygeek119.duckdns.org/",
    "StatusPublicUrl": "https://ravastatus.binarygeek119.duckdns.org/"
  }
}
